rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isVerifiedUser() {
      return isAuthenticated() && (request.auth.token.email_verified == true || request.auth.token.email == "admin@domain.com");
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function getProfile(uid) {
      return get(/databases/$(database)/documents/profiles/$(uid)).data;
    }

    function hasValidProfileLinkage(userId) {
      return isOwner(userId) && getProfile(userId) != null;
    }

    // Profiles Collection:
    // Anyone can read profiles to search by email or load shared library.
    // Only the user themselves can write their own profile.
    match /profiles/{uid} {
      allow read: if true;
      allow create, update, delete: if isOwner(uid);
    }

    // Users Database:
    // Anyone can read user tracking data for sharing.
    // Writes (create, update, delete) are tightly verified using request.auth for ownership.
    match /users/{userId} {
      allow read: if true;
      allow write: if hasValidProfileLinkage(userId);

      match /settings/{docId} {
        allow read: if true;
        allow write: if hasValidProfileLinkage(userId);
      }

      match /watchlist/{docId} {
        allow read: if true;
        allow write: if hasValidProfileLinkage(userId);
      }

      match /favorites/{docId} {
        allow read: if true;
        allow write: if hasValidProfileLinkage(userId);
      }

      match /show_progress/{docId} {
        allow read: if true;
        allow write: if hasValidProfileLinkage(userId);
      }

      match /watched_episodes/{docId} {
        allow read: if true;
        allow write: if hasValidProfileLinkage(userId);
      }

      match /watched_movies/{docId} {
        allow read: if true;
        allow write: if hasValidProfileLinkage(userId);
      }

      match /ratings/{docId} {
        allow read: if true;
        allow create, update: if hasValidProfileLinkage(userId) 
                             && request.resource.data.rating >= 1 
                             && request.resource.data.rating <= 10;
        allow delete: if hasValidProfileLinkage(userId);
      }

      match /notes/{docId} {
        allow read: if true;
        allow write: if hasValidProfileLinkage(userId);
      }

      match /custom_lists/{docId} {
        allow read: if true;
        allow write: if hasValidProfileLinkage(userId);
      }
    }
  }
}
